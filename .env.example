# Drafts Web Capture Configuration

# Required: Password for web interface access
CAPTURE_PASSWORD=change_this_to_a_secure_password

# Required for TailScale sidecar: Your TailScale auth key
TAILSCALE_AUTHKEY=your-tailscale-auth-key

# Optional: Port to run on (default: 3000)
PORT=3000

# Optional: Database file path (default: ./data/drafts.db)
DATABASE_PATH=./data/drafts.db

# Optional: Enable verbose logging (default: false)
DEBUG=false